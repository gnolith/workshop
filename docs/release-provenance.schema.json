{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gnolith/workshop/blob/main/docs/release-provenance.schema.json",
  "title": "Workshop release artifact provenance",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "package",
    "source",
    "environment",
    "artifact"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "package": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "@gnolith/workshop" },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["commit", "tree", "dirty", "stateSha256"],
      "properties": {
        "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "tree": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "dirty": { "type": "boolean" },
        "stateSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": [
        "platform",
        "release",
        "version",
        "arch",
        "node",
        "npm",
        "git",
        "coreAutocrlf"
      ],
      "properties": {
        "platform": { "type": "string", "minLength": 1 },
        "release": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "arch": { "type": "string", "minLength": 1 },
        "node": { "type": "string", "pattern": "^v[0-9]+\\." },
        "npm": { "type": "string", "minLength": 1 },
        "git": { "type": "string", "pattern": "^git version " },
        "coreAutocrlf": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": [
        "filename",
        "size",
        "sha256",
        "shasum",
        "integrity",
        "files"
      ],
      "properties": {
        "filename": {
          "type": "string",
          "pattern": "^gnolith-workshop-[0-9A-Za-z.-]+\\.tgz$"
        },
        "size": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "shasum": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "integrity": {
          "type": "string",
          "pattern": "^sha512-[A-Za-z0-9+/]+={0,2}$"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "size", "mode"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "size": { "type": "integer", "minimum": 0 },
              "mode": { "type": "integer", "minimum": 0, "maximum": 511 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
